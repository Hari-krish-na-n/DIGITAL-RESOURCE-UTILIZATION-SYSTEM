{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "https://drus-backend.onrender.com/api/:path*"
    },
    {
      "source": "/(render-.*)",
      "destination": "https://drus-backend.onrender.com/$1"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
